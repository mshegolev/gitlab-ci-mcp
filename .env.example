# Copy to .env and fill in your values. Never commit the real file.

GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_PROJECT_PATH=my-org/my-repo

# Optional — defaults are fine for public GitLab instances
GITLAB_SSL_VERIFY=true

# Only needed when GitLab is on an intranet reached through a local HTTP proxy
# that would otherwise intercept internal traffic.
GITLAB_NO_PROXY_DOMAINS=
